{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rustmine.local/schemas/client-load-test-manifest.schema.json",
  "title": "Client Load Test Manifest",
  "type": "object",
  "required": [
    "manifest_id",
    "case_id",
    "load_phase",
    "test_surface",
    "proof_command",
    "expected_artifacts",
    "done_condition"
  ],
  "properties": {
    "manifest_id": { "type": "string", "pattern": "^[a-z0-9_\\-]+$" },
    "case_id": { "type": "string", "pattern": "^[a-z0-9_\\-]+$" },
    "load_phase": { "type": "string" },
    "test_surface": { "type": "string" },
    "proof_command": { "type": "string" },
    "expected_artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "done_condition": { "type": "string" },
    "stop_boundary": { "type": "string" }
  },
  "additionalProperties": false
}
