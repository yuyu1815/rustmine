{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rustmine.local/schemas/rust-fix-task.schema.json",
  "title": "Stevenarella Rust Fix Task",
  "type": "object",
  "required": [
    "task_id",
    "case_id",
    "why",
    "what",
    "answer_path",
    "failing_test",
    "allowed_write_scope",
    "forbidden_paths",
    "stop_condition"
  ],
  "properties": {
    "task_id": { "type": "string" },
    "case_id": { "type": "string" },
    "why": { "type": "string" },
    "what": { "type": "string" },
    "answer_path": { "type": "string" },
    "contract_path": { "type": "string" },
    "failing_test": { "type": "string" },
    "allowed_write_scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "forbidden_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "stop_condition": { "type": "string" }
  },
  "additionalProperties": false
}
