{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rustmine.local/schemas/why-what-answer.schema.json",
  "title": "Oracle Failure Why What Answer",
  "$comment": "Closed enums list currently known values. Extend this schema when new valid owners appear rather than forcing them into the closest existing value.",
  "type": "object",
  "required": [
    "case_id",
    "why",
    "what",
    "answer",
    "evidence",
    "next_owner"
  ],
  "properties": {
    "case_id": { "type": "string" },
    "why": { "type": "string" },
    "what": { "type": "string" },
    "answer": { "type": "object" },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "summary"],
        "properties": {
          "path": { "type": "string" },
          "summary": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "next_owner": {
      "type": "string",
      "description": "Currently known next-owner routes; extend this enum for new valid ownership routes.",
      "enum": ["oracle_workbench", "rust_worker", "direction_review", "blocked"]
    }
  },
  "additionalProperties": false
}
