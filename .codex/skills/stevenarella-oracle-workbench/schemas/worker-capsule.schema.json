{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rustmine.local/schemas/worker-capsule.schema.json",
  "title": "Worker Capsule",
  "$comment": "Machine contract for direct parent-to-worker delegation. Use this when Parent Codex delegates one bounded worker without a Lead/planner. It keeps startup reads, write scope, checks, and return shape explicit.",
  "type": "object",
  "required": [
    "schema_version",
    "worker_role",
    "objective",
    "startup_context",
    "allowed_reads",
    "allowed_writes",
    "required_evidence",
    "required_checks",
    "exit_condition",
    "stop_boundary",
    "write_policy",
    "return_contract"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "worker-capsule/v1"
    },
    "worker_role": {
      "type": "string",
      "enum": [
        "rustmine_oracle_cartographer",
        "rustmine_rust_implementer",
        "rustmine_test_surface_mapper",
        "rustmine_compatibility_critic"
      ]
    },
    "objective": { "type": "string", "minLength": 1 },
    "startup_context": {
      "type": "object",
      "required": ["current_location", "known_facts", "do_not_read_by_default"],
      "properties": {
        "current_location": { "type": "string", "minLength": 1 },
        "known_facts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "do_not_read_by_default": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/path_entry" }
        }
      },
      "additionalProperties": false
    },
    "allowed_reads": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/path_entry" }
    },
    "allowed_writes": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/write_path_entry" }
    },
    "required_evidence": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_checks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "exit_condition": { "type": "string", "minLength": 1 },
    "stop_boundary": { "type": "string", "minLength": 1 },
    "fragile_preconditions": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "write_policy": {
      "type": "object",
      "required": ["mode", "post_run_diff_check", "diff_baseline"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["read_only", "workspace_write"]
        },
        "post_run_diff_check": {
          "type": "boolean",
          "const": true
        },
        "diff_baseline": {
          "type": "object",
          "required": ["before_command", "after_command", "delta_rule"],
          "properties": {
            "before_command": {
              "type": "string",
              "const": "git status --porcelain=v1 --untracked-files=all -- ."
            },
            "after_command": {
              "type": "string",
              "const": "git status --porcelain=v1 --untracked-files=all -- ."
            },
            "delta_rule": {
              "type": "string",
              "const": "after_minus_before_status_paths_must_be_subset_of_allowed_writes"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "rust_fix_task_path": { "$ref": "#/$defs/write_path_reference" },
    "return_contract": {
      "type": "object",
      "required": ["must_report", "must_not_claim"],
      "properties": {
        "must_report": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "must_not_claim": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "write_policy": {
            "properties": {
              "mode": { "const": "workspace_write" }
            },
            "required": ["mode"]
          }
        },
        "required": ["write_policy"]
      },
      "then": {
        "properties": {
          "allowed_writes": { "minItems": 1 }
        }
      }
    },
    {
      "if": {
        "properties": {
          "write_policy": {
            "properties": {
              "mode": { "const": "read_only" }
            },
            "required": ["mode"]
          }
        },
        "required": ["write_policy"]
      },
      "then": {
        "properties": {
          "allowed_writes": { "maxItems": 0 }
        }
      }
    },
    {
      "if": {
        "properties": {
          "worker_role": {
            "enum": [
              "rustmine_test_surface_mapper",
              "rustmine_compatibility_critic"
            ]
          }
        },
        "required": ["worker_role"]
      },
      "then": {
        "properties": {
          "allowed_writes": { "maxItems": 0 },
          "write_policy": {
            "properties": {
              "mode": { "const": "read_only" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "worker_role": {
            "const": "rustmine_rust_implementer"
          }
        },
        "required": ["worker_role"]
      },
      "then": {
        "required": ["rust_fix_task_path"]
      }
    }
  ],
  "$defs": {
    "path_entry": {
      "type": "object",
      "required": ["path", "kind", "scope", "reason"],
      "properties": {
        "path": { "$ref": "#/$defs/normalized_project_path" },
        "kind": {
          "type": "string",
          "enum": ["file", "directory"]
        },
        "scope": {
          "type": "string",
          "enum": ["exact", "subtree"]
        },
        "reason": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "write_path_entry": {
      "allOf": [
        { "$ref": "#/$defs/path_entry" },
        {
          "properties": {
            "kind": { "const": "file" },
            "scope": { "const": "exact" }
          }
        }
      ]
    },
    "write_path_reference": {
      "allOf": [
        { "$ref": "#/$defs/path_entry" },
        {
          "properties": {
            "kind": { "const": "file" },
            "scope": { "const": "exact" }
          }
        }
      ]
    },
    "normalized_project_path": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          { "pattern": "^/" },
          { "pattern": "^\\./" },
          { "pattern": "(^|/)\\.\\.?(/|$)" },
          { "pattern": "[\\\\*?\\[\\]{}]" }
        ]
      }
    }
  },
  "additionalProperties": false
}
