{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rustmine.local/schemas/oracle-test-manifest.schema.json",
  "title": "Versioned Oracle Test Manifest",
  "$comment": "Closed enums list currently known values. Extend this schema when new valid domains appear rather than forcing them into the closest existing value.",
  "type": "object",
  "required": [
    "manifest_id",
    "case_id",
    "contract_path",
    "answer_path",
    "rust_test_target",
    "rust_test_name",
    "comparison_surface",
    "official_source",
    "internal_owner",
    "corridor",
    "stop_boundary"
  ],
  "properties": {
    "manifest_id": { "type": "string", "pattern": "^[a-z0-9_\\-]+$" },
    "case_id": { "type": "string", "pattern": "^[a-z0-9_\\-]+$" },
    "contract_path": { "type": "string" },
    "answer_path": { "type": "string" },
    "rust_test_target": { "type": "string" },
    "rust_test_name": { "type": "string" },
    "comparison_surface": {
      "type": "string",
      "description": "Currently known comparison surfaces; extend this enum for new valid test surfaces.",
      "enum": [
        "packet_id",
        "encoded_body",
        "codec_body_only",
        "decoded_fields",
        "state_transition",
        "runtime_reaction",
        "corridor"
      ]
    },
    "comparison_surface_note": {
      "type": "string",
      "description": "Clarifies the exact surface compared by this manifest when the enum value alone is too broad."
    },
    "test_topology_note": {
      "type": "string",
      "description": "Clarifies how the manifest's Rust target and test name relate to the current runnable test topology."
    },
    "official_source": {
      "type": "object",
      "required": ["jar_role", "jar_path", "function_or_member"],
      "properties": {
        "jar_role": {
          "type": "string",
          "description": "Currently known jar roles; extend this enum if a future official source role is valid.",
          "enum": ["client", "server", "merged"]
        },
        "jar_path": { "type": "string" },
        "function_or_member": { "type": "string" },
        "decompiled_source_path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "internal_owner": {
      "type": "object",
      "required": ["domain", "path", "symbol_or_test_surface"],
      "properties": {
        "domain": {
          "type": "string",
          "description": "Currently known internal owner domains; extend this enum when new valid ownership domains appear.",
          "enum": ["wire_protocol", "internal_packet_model", "runtime_behavior", "verification_probe"]
        },
        "path": { "type": "string" },
        "symbol_or_test_surface": { "type": "string" },
        "scope_note": {
          "type": "string",
          "description": "Clarifies that the owner is scoped to this manifest surface and is not a universal ownership claim."
        }
      },
      "additionalProperties": false
    },
    "corridor": { "type": "string" },
    "traceability_path": { "type": "string" },
    "stop_boundary": { "type": "string" }
  },
  "additionalProperties": false
}
