{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rustmine.local/schemas/oracle-contract.schema.json",
  "title": "Versioned Oracle Contract",
  "$comment": "Closed enums list currently known values. Extend this schema when new valid domains appear rather than forcing them into the closest existing value.",
  "type": "object",
  "required": [
    "contract_id",
    "case_id",
    "scope",
    "official_functions",
    "invariants",
    "answer_path"
  ],
  "properties": {
    "contract_id": { "type": "string" },
    "case_id": { "type": "string" },
    "scope": {
      "type": "string",
      "description": "Currently known contract scopes; extend this enum for new valid compatibility scopes.",
      "enum": ["codec", "state_transition", "runtime_reaction", "corridor"]
    },
    "official_functions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "function_or_member", "role"],
        "properties": {
          "path": { "type": "string" },
          "function_or_member": { "type": "string" },
          "role": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "invariants": {
      "type": "array",
      "items": { "type": "string" }
    },
    "answer_path": { "type": "string" },
    "rust_test_target": { "type": "string" },
    "test_topology_note": {
      "type": "string",
      "description": "Clarifies how the named Rust target relates to the current runnable test topology."
    },
    "stop_boundary": { "type": "string" }
  },
  "additionalProperties": false
}
