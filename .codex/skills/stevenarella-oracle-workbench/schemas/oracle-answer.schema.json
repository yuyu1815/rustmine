{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rustmine.local/schemas/oracle-answer.schema.json",
  "title": "Versioned Oracle Answer",
  "$comment": "Closed enums list currently known values. Extend this schema when new valid domains appear rather than forcing them into the closest existing value.",
  "type": "object",
  "required": [
    "case_id",
    "generated_by",
    "official_source",
    "answer"
  ],
  "properties": {
    "case_id": { "type": "string" },
    "generated_by": {
      "type": "object",
      "required": ["tool", "version_manifest"],
      "properties": {
        "tool": { "type": "string" },
        "version_manifest": { "type": "string" },
        "timestamp_utc": { "type": "string" }
      },
      "additionalProperties": false
    },
    "official_source": {
      "type": "object",
      "required": ["jar_role", "jar_path", "sha1", "function_or_member"],
      "properties": {
        "jar_role": {
          "type": "string",
          "description": "Currently known jar roles; extend this enum if a future official source role is valid.",
          "enum": ["client", "server", "merged"]
        },
        "jar_path": { "type": "string" },
        "sha1": { "type": "string" },
        "function_or_member": { "type": "string" },
        "decompiled_source_path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "answer": { "type": "object" }
  },
  "additionalProperties": false
}
